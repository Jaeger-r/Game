# Copy to /opt/jaeger-server/server.env and fill in real values when needed.
# Leave this file out entirely if you prefer to keep credentials in server.json.

JAEGER_SERVER_POSTGRES_HOST=127.0.0.1
JAEGER_SERVER_POSTGRES_PORT=5432
JAEGER_SERVER_POSTGRES_USER=jaeger_server
JAEGER_SERVER_POSTGRES_PASSWORD=replace_me
JAEGER_SERVER_POSTGRES_DATABASE=disk
JAEGER_SERVER_POSTGRES_POOL_SIZE=10
