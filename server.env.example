# Copy to /opt/jaeger-server/server.env and fill in real values when needed.
# Leave this file out entirely if you prefer to keep credentials in server.json.

JAEGER_SERVER_MYSQL_HOST=127.0.0.1
JAEGER_SERVER_MYSQL_PORT=3306
JAEGER_SERVER_MYSQL_USER=jaeger_server
JAEGER_SERVER_MYSQL_PASSWORD=replace_me
JAEGER_SERVER_MYSQL_DATABASE=disk
JAEGER_SERVER_MYSQL_POOL_SIZE=10
