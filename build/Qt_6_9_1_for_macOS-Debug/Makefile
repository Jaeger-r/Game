GameServer.app/Contents/PkgInfo: 
	@test -d GameServer.app/Contents || mkdir -p GameServer.app/Contents
	@$(DEL_FILE) GameServer.app/Contents/PkgInfo
	@echo "APPL????" > GameServer.app/Contents/PkgInfo
GameServer.app/Contents/Info.plist: 
	@test -d GameServer.app/Contents || mkdir -p GameServer.app/Contents
	@$(DEL_FILE) GameServer.app/Contents/Info.plist
	@plutil -convert xml1 -o - ../../../../Qt/6.9.1/macos/mkspecs/macx-clang/Info.plist.app | sed -e "s,@SHORT_VERSION@,1.0,g" -e "s,\$${QMAKE_SHORT_VERSION},1.0,g" -e "s,@FULL_VERSION@,1.0.0,g" -e "s,\$${QMAKE_FULL_VERSION},1.0.0,g" -e "s,@TYPEINFO@,????,g" -e "s,\$${QMAKE_PKGINFO_TYPEINFO},????,g" -e "s,@BUNDLEIDENTIFIER@,jaeger.GameServer,g" -e "s,\$${PRODUCT_BUNDLE_IDENTIFIER},jaeger.GameServer,g" -e "s,\$${MACOSX_DEPLOYMENT_TARGET},12,g" -e "s,\$${IPHONEOS_DEPLOYMENT_TARGET},,g" -e "s,\$${TVOS_DEPLOYMENT_TARGET},,g" -e "s,\$${WATCHOS_DEPLOYMENT_TARGET},,g" -e "s,\$${IOS_LAUNCH_SCREEN},LaunchScreen,g" -e "s,@ICON@,,g" -e "s,\$${ASSETCATALOG_COMPILER_APPICON_NAME},,g" -e "s,@EXECUTABLE@,GameServer,g" -e "s,@LIBRARY@,GameServer,g" -e "s,\$${EXECUTABLE_NAME},GameServer,g" -e "s,@TYPEINFO@,????,g" -e "s,\$${QMAKE_PKGINFO_TYPEINFO},????,g" >GameServer.app/Contents/Info.plist

