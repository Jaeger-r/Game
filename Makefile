####### Install

install_target: first FORCE
	@test -d $(INSTALL_ROOT)/opt/GameServer/bin || mkdir -p $(INSTALL_ROOT)/opt/GameServer/bin
	$(DEL_FILE) -r $(INSTALL_ROOT)/opt/GameServer/bin/GameServer.app
	
	$(QINSTALL) GameServer.app $(INSTALL_ROOT)/opt/GameServer/bin/GameServer.app

uninstall_target: FORCE
	-$(DEL_FILE) -r $(INSTALL_ROOT)/opt/GameServer/bin/GameServer.app
	-$(DEL_DIR) $(INSTALL_ROOT)/opt/GameServer/bin/ 


install: install_target  FORCE

uninstall: uninstall_target  FORCE

